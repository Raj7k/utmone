# Example secrets file - DO NOT commit actual secrets to git
# Copy this to secrets.yaml and update with your actual values
# Then apply with: kubectl apply -f secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: utm-one-secrets
type: Opaque
stringData:
  # PostgreSQL connection string
  # Format: postgresql://username:password@host:port/database
  database-url: "postgresql://utm_one_user:CHANGEME@postgres-service:5432/utm_one"
  
  # Optional: JWT secret for API authentication
  jwt-secret: "CHANGEME-GENERATE-WITH-openssl-rand-base64-32"

# To create from command line:
# kubectl create secret generic utm-one-secrets \
#   --from-literal=database-url='postgresql://...' \
#   --from-literal=jwt-secret='...'
