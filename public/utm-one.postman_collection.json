{
  "info": {
    "name": "utm.one API",
    "description": "Complete API collection for utm.one",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "x-api-key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{api_key}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.utm.one",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "utm_your_api_key_here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Links",
      "item": [
        {
          "name": "List Links",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/links?page=1&per_page=50",
              "host": ["{{base_url}}"],
              "path": ["v1", "links"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Create Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Summer Campaign\",\n  \"destination_url\": \"https://example.com/summer\",\n  \"slug\": \"summer-2024\",\n  \"utm_source\": \"facebook\",\n  \"utm_medium\": \"social\",\n  \"utm_campaign\": \"summer-launch\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/links",
              "host": ["{{base_url}}"],
              "path": ["v1", "links"]
            }
          }
        },
        {
          "name": "Get Link",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/links/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "links", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "link-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Update Link",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"destination_url\": \"https://example.com/new-url\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/links/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "links", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "link-id-here"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Link",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/links/:id",
              "host": ["{{base_url}}"],
              "path": ["v1", "links", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "link-id-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Link Analytics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/v1/links/:id/analytics?date_range=last-30-days",
              "host": ["{{base_url}}"],
              "path": ["v1", "links", ":id", "analytics"],
              "query": [
                {
                  "key": "date_range",
                  "value": "last-30-days"
                }
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "link-id-here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Track Conversion Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"link_id\": \"link-id-here\",\n  \"event_type\": \"purchase\",\n  \"event_value\": 49.99,\n  \"currency\": \"USD\",\n  \"metadata\": {\n    \"order_id\": \"ORD-123\",\n    \"product\": \"Premium Plan\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/events",
              "host": ["{{base_url}}"],
              "path": ["v1", "events"]
            }
          }
        }
      ]
    }
  ]
}
